      <section id="events-section" class="events-section">
        <div class="section-inner">
          <h2>Upcoming Events</h2>
          <div class="events-list">
            <!-- original event items preserved -->
          </div>
        </div>
      </section>

      <section id="brochures-section" class="brochures-section">
        <div class="section-inner">
          <h2>Download Brochures</h2>
          <div class="brochures-grid">
            <!-- original brochure cards preserved -->
          </div>
        </div>
      </section>

      <section id="admission-email-section" class="admission-email-section">
        <div class="section-inner">
          <h2>Ready for 2026 Admission?</h2>
          <p>Choose a college and email us for step-by-step admission guidance.</p>
          <a href="mailto:nishedk076@gmail.com" class="btn btn-primary">Email for Admission</a>
        </div>
      </section>

      <section id="contact" class="contact-section">
        <div class="section-inner">
          <h3>Contact</h3>
          <p>Email: <a href="mailto:nishedk076@gmail.com">nishedk076@gmail.com</a></p>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div>© 2026 Private College Portal</div>
        <div class="social">
          <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
          <a href="#"><i class="fa-brands fa-linkedin-in"></i></a>
          <a href="#"><i class="fa-brands fa-twitter"></i></a>
        </div>
      </div>
    </footer>
  </div>

  <!-- Modal, Chatbot and scripts remain; keep original script links -->
  <div id="detailsModal" class="modal hidden">
    <div class="modal-content">
      <span class="close-modal" onclick="closeDetails()">&times;</span>
      <div id="modalBody"></div>
    </div>
  </div>

  <div id="chatbotContainer"></div>

  <script src="script.js"></script>
  <script src="gemini-api.js"></script>
  <script src="ai-chat.js"></script>
  <script src="effects.js"></script>
</body>
</html>
