<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Private College Portal — 2026 Admissions</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <div class="site-wrap">
    <header class="site-header">
      <div class="topbar">🎓 2026 Admissions Open — Limited Seats Available</div>
      <div class="header-inner">
        <a class="brand" href="#">
          <img src="assets/images/lpu-logo.png" alt="logo" class="brand-logo">
          <div class="brand-text"><strong>LPU‑Style Portal</strong><small>Admissions &amp; Guidance</small></div>
        </a>
        <nav class="main-nav" id="mainNav">
          <a href="#universities-section">Colleges</a>
          <a href="#ai-section">AI Tools</a>
          <a href="#events-section">Events</a>
          <a href="#brochures-section">Brochures</a>
        </nav>
        <div class="header-cta">
          <a href="#admission-email-section" class="btn btn-primary">Apply Now</a>
          <a href="mailto:nishedk076@gmail.com" class="btn btn-secondary">Contact</a>
        </div>
      </div>
      </header>

    <main>
      <section id="ai-section" class="ai-powered-features-section">
        <div class="section-inner">
          <h2>Smart Tools</h2>
          <p class="lede">AI tools to recommend courses and check eligibility in seconds.</p>
          <div class="ai-grid">
            <div class="card">
              <div class="card-head">AI Course Recommender</div>
              <p>Select interests and get tailored course + college suggestions.</p>
              <div class="card-actions">
                <select id="interestSelector">
                  <option value="technology">Technology</option>
                  <option value="business">Business</option>
                  <option value="law">Law</option>
                  <option value="arts">Arts</option>
                </select>
                <button class="btn" onclick="recommendCourse()">Recommend</button>
              </div>
              <div id="courseRecommendation" class="result"></div>
            </div>

            <div class="card">
              <div class="card-head">Eligibility Checker</div>
              <p>Quickly determine the colleges you qualify for.</p>
              <div class="card-actions">
                <input type="number" id="userMarks" placeholder="Enter your 12th %">
                <select id="courseSelector">
                  <option value="engineering">Engineering</option>
                  <option value="management">Management</option>
                  <option value="law">Law</option>
                </select>
                <button class="btn" onclick="checkEligibility()">Check</button>
              </div>
              <div id="eligibilityResult" class="result"></div>
            </div>
          </div>
        </div>
      </section>

      <section class="universities-section">
            <h2 class="section-title rainbow-text">Private Colleges - 2026 Admission | Detailed Fees & Hostel Information</h2>
            <div class="universities-list">
                
                <!-- University Item -->
                <div class="university-list-item" data-state="noida engineering">
                    <div class="uni-image">
                        <img src="https://source.unsplash.com/featured/600x400/?Delhi%20Institute%20of%20Technology%20campus" alt="Delhi Institute of Technology">
                    </div>
                    <div class="uni-details">
                        <h3>Delhi Institute of Technology</h3>
                        <p>Noida, UP</p>
                        <div class="uni-tags">
                            <span class="badge badge-private">Private Engineering</span>
                            <span class="badge badge-open">2026 Open</span>
                        </div>
                    </div>
                    <div class="uni-actions">
                        <button class="select-btn" onclick="showDetails('Delhi Institute of Technology')">View Details</button>
                    </div>
                </div>

                <!-- University Item -->
                <div class="university-list-item" data-state="noida engineering">
                    <div class="uni-image">
                        <img src="https://source.unsplash.com/featured/600x400/?Galgotias%20University%20campus" alt="Galgotias University">
                    </div>
                    <div class="uni-details">
                        <h3>Galgotias University</h3>
                        <p>Greater Noida, UP</p>
                        <div class="uni-tags">
                            <span class="badge badge-private">Engineering & Management</span>
                            <span class="badge badge-open">2026 Open</span>
                        </div>
                    </div>
                    <div class="uni-actions">
                        <button class="select-btn" onclick="showDetails('Galgotias University')">View Details</button>
                    </div>
                </div>

                <!-- University Item -->
                <div class="university-list-item" data-state="noida engineering">
